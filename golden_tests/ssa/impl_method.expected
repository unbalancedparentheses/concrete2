; module main
define i64 @consume(%Counter %c) {
entry:
  %t0 = gep i64 %c, i64 0
  %t1 = load i64, %t0
  ret i64 %t1
}

define i64 @main() {
entry:
  %t0 = alloca %Counter
  %t1 = gep i64 %t0, i64 0
  store i64 42, %t1
  %t2 = load %Counter, %t0
  %t3 = call i64 @Counter_get(%Counter %t2)
  %t4 = call i64 @consume(%Counter %t2)
  ret i64 %t3
}

define i64 @Counter_get(ptr(%Counter) %self) {
entry:
  %t0 = gep i64 %self, i64 0
  %t1 = load i64, %t0
  ret i64 %t1
}
