; module main
define i64 @main() {
entry:
  %t0 = alloca [3 x i64]
  %t1 = gep i64 %t0, i64 0
  store i64 10, %t1
  %t2 = gep i64 %t0, i64 1
  store i64 20, %t2
  %t3 = gep i64 %t0, i64 2
  store i64 30, %t3
  %t4 = load [3 x i64], %t0
  %t5 = gep i64 %t4, i64 0
  %t6 = load i64, %t5
  %t7 = gep i64 %t4, i64 2
  %t8 = load i64, %t7
  %t9 = add i64 %t6, %t8
  ret i64 %t9
}
