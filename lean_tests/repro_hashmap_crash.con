// Reproducer attempt for HashMap<i32, i32> runtime crash (SIGBUS/SIGSEGV)
//
// FINDINGS:
// 1. The crash CANNOT be reproduced with the current compiler because the
//    linearity checker prevents the generic `insert` method from compiling
//    when monomorphized. Type variable params (K, V) are always treated as
//    linear (Check.lean line 411: `.typeVar _ => return false`), so
//    `value: V` consumed conditionally inside a while loop fails the check.
//
// 2. The user-defined HashMap in std/src/map.con only compiles because its
//    methods are never monomorphized -- no code calls them. The compiler
//    replaces HashMap operations with builtin LLVM IR implementations
//    (see Codegen/Builtins.lean: __hashmap_int_insert, etc.)
//
// 3. The builtin HashMap only supports Int and String keys (not i32),
//    and uses a 5-field struct layout (no fn pointer fields). It works
//    correctly under heavy stress testing.
//
// 4. All other generic patterns work correctly:
//    - Generic struct with fn(&K) pointer fields: correct codegen
//    - Fn ptr indirect calls through generic struct fields: works
//    - Ptr arithmetic on generic typed arrays: correct element sizing
//    - While-loop linear scan with fn ptr dispatch: works
//    - Multiple monomorphizations of same generic: works
//
// 5. The non-generic version (concrete i32 types) of the full HashMap
//    with insert/get/remove/grow/tombstones works perfectly.
//
// CONCLUSION: The crash was in a prior compiler version where the linearity
// check was less strict. The generic insert that consumes K and V in
// conditional while-loop branches likely had a codegen bug that has since
// been masked by the stricter linearity checking. The bug may resurface
// when generic Copy inference is improved (so K, V get Copy propagation).

extern fn malloc(size: u64) -> *mut u8;
extern fn realloc(ptr: *mut u8, size: u64) -> *mut u8;
extern fn free(ptr: *mut u8);
extern fn memset(ptr: *mut u8, value: i32, n: u64) -> *mut u8;

#[intrinsic = "sizeof"]
fn sizeof<T>() -> u64;

fn hash_i32(k: &i32) -> u64 {
    let v: i32 = *k;
    return v as u64;
}

fn eq_i32(a: &i32, b: &i32) -> bool {
    return *a == *b;
}

// ===== TEST A: Generic struct with fn ptr fields =====
struct Container<K> {
    data:    *mut K,
    cap:     u64,
    hash_fn: fn(&K) -> u64,
    eq_fn:   fn(&K, &K) -> bool,
}

trusted impl<K> Container<K> {
    pub fn new(hf: fn(&K) -> u64, ef: fn(&K, &K) -> bool, cap: u64) with(Alloc, Unsafe) -> Container<K> {
        let data: *mut K = malloc(sizeof::<K>() * cap) as *mut K;
        return Container::<K> { data: data, cap: cap, hash_fn: hf, eq_fn: ef };
    }
    pub fn write(&self, idx: u64, val: K) {
        let p: *mut K = self.data + idx;
        *p = val;
    }
    pub fn read(&self, idx: u64) -> K {
        let p: *mut K = self.data + idx;
        return *p;
    }
    pub fn hash_at(&self, idx: u64) -> u64 {
        let p: *mut K = self.data + idx;
        let f: fn(&K) -> u64 = self.hash_fn;
        return f(p as &K);
    }
    pub fn find(&self, key: &K) -> u64 {
        let f: fn(&K) -> u64 = self.hash_fn;
        let h: u64 = f(key);
        let mask: u64 = self.cap - 1;
        let mut idx: u64 = h & mask;
        let mut count: u64 = 0;
        while count < self.cap {
            let p: *mut K = self.data + idx;
            let ef: fn(&K, &K) -> bool = self.eq_fn;
            if ef(p as &K, key) { return idx; }
            idx = (idx + 1) & mask;
            count = count + 1;
        }
        return self.cap;
    }
}

trusted fn free_container(c: Container<i32>) with(Alloc, Unsafe) {
    free(c.data as *mut u8);
}

// ===== TEST B: Non-generic HashMap with full insert/grow =====
struct Copy IntMap {
    keys: *mut i32, values: *mut i32, flags: *mut u8,
    len: u64, cap: u64,
    hash_fn: fn(&i32) -> u64, eq_fn: fn(&i32, &i32) -> bool,
}

trusted impl IntMap {
    pub fn new(hf: fn(&i32) -> u64, ef: fn(&i32, &i32) -> bool) with(Alloc, Unsafe) -> IntMap {
        let cap: u64 = 4;
        let keys: *mut i32 = realloc(0 as *mut u8, 4 * cap) as *mut i32;
        let values: *mut i32 = realloc(0 as *mut u8, 4 * cap) as *mut i32;
        let flags: *mut u8 = realloc(0 as *mut u8, cap) as *mut u8;
        memset(flags, 0, cap);
        return IntMap { keys: keys, values: values, flags: flags,
                        len: 0, cap: cap, hash_fn: hf, eq_fn: ef };
    }
    pub fn insert(&mut self, key: i32, value: i32) with(Alloc, Unsafe) {
        if self.len * 4 >= self.cap * 3 { self.grow(); }
        let hash_f: fn(&i32) -> u64 = self.hash_fn;
        let h: u64 = hash_f(&key);
        let mask: u64 = self.cap - 1;
        let mut idx: u64 = h & mask;
        while true {
            let fp: *mut u8 = self.flags + idx;
            let f: u8 = *fp;
            if f == 0 || f == 2 {
                let kp: *mut i32 = self.keys + idx; *kp = key;
                let vp: *mut i32 = self.values + idx; *vp = value;
                *fp = 1; self.len = self.len + 1; return;
            }
            if f == 1 {
                let kp: *mut i32 = self.keys + idx;
                let ef: fn(&i32, &i32) -> bool = self.eq_fn;
                if ef(kp as &i32, &key) {
                    let vp: *mut i32 = self.values + idx; *vp = value; *kp = key; return;
                }
            }
            idx = (idx + 1) & mask;
        }
    }
    fn find_slot(&self, key: &i32) -> u64 {
        let hash_f: fn(&i32) -> u64 = self.hash_fn;
        let h: u64 = hash_f(key);
        let mask: u64 = self.cap - 1;
        let mut idx: u64 = h & mask;
        while true {
            let fp: *mut u8 = self.flags + idx;
            let f: u8 = *fp;
            if f == 0 { return idx; }
            if f == 1 {
                let kp: *mut i32 = self.keys + idx;
                let ef: fn(&i32, &i32) -> bool = self.eq_fn;
                if ef(kp as &i32, key) { return idx; }
            }
            idx = (idx + 1) & mask;
        }
        return 0;
    }
    pub fn get(&self, key: &i32) -> i32 {
        let idx: u64 = self.find_slot(key);
        let fp: *mut u8 = self.flags + idx;
        if *fp == 1 { let vp: *mut i32 = self.values + idx; return *vp; }
        return -1;
    }
    pub fn remove(&mut self, key: &i32) -> bool {
        let idx: u64 = self.find_slot(key);
        let fp: *mut u8 = self.flags + idx;
        if *fp != 1 { return false; }
        *fp = 2; self.len = self.len - 1; return true;
    }
    fn grow(&mut self) with(Alloc, Unsafe) {
        let oc: u64 = self.cap;
        let ok: *mut i32 = self.keys; let ov: *mut i32 = self.values; let of: *mut u8 = self.flags;
        let nc: u64 = oc * 2;
        self.keys = realloc(0 as *mut u8, 4 * nc) as *mut i32;
        self.values = realloc(0 as *mut u8, 4 * nc) as *mut i32;
        self.flags = realloc(0 as *mut u8, nc) as *mut u8;
        memset(self.flags, 0, nc); self.cap = nc; self.len = 0;
        let mut i: u64 = 0;
        while i < oc {
            let fp: *mut u8 = of + i;
            if *fp == 1 {
                let kp: *mut i32 = ok + i; let vp: *mut i32 = ov + i;
                self.insert_for_grow(*kp, *vp);
            }
            i = i + 1;
        }
        free(ok as *mut u8); free(ov as *mut u8); free(of as *mut u8);
    }
    fn insert_for_grow(&mut self, key: i32, value: i32) {
        let hash_f: fn(&i32) -> u64 = self.hash_fn;
        let h: u64 = hash_f(&key);
        let mask: u64 = self.cap - 1;
        let mut idx: u64 = h & mask;
        while true {
            let fp: *mut u8 = self.flags + idx;
            if *fp == 0 {
                let kp: *mut i32 = self.keys + idx; *kp = key;
                let vp: *mut i32 = self.values + idx; *vp = value;
                *fp = 1; self.len = self.len + 1; return;
            }
            idx = (idx + 1) & mask;
        }
    }
}

trusted fn free_intmap(m: IntMap) with(Alloc, Unsafe) {
    free(m.keys as *mut u8); free(m.values as *mut u8); free(m.flags as *mut u8);
}

fn main() with(Alloc, Unsafe) -> i32 {
    // --- Test A: Generic struct with fn ptr fields ---
    let c: Container<i32> = Container::<i32>::new(hash_i32, eq_i32, 16);
    c.write(0, 42);
    c.write(5, 777);
    let v0: i32 = c.read(0);
    let h0: u64 = c.hash_at(0);
    let k1: i32 = 42;
    c.write(10, 42);
    let f1: u64 = c.find(&k1);
    free_container(c);
    if v0 != 42 { return 1; }
    if h0 != 42 { return 2; }

    // --- Test B: Non-generic HashMap with grow ---
    let mut m: IntMap = IntMap::new(hash_i32, eq_i32);
    // 25 inserts: forces grow 4->8->16->32
    let mut i: i32 = 0;
    while i < 25 { m.insert(i, i * 10); i = i + 1; }
    // Verify all
    let mut j: i32 = 0;
    while j < 25 {
        let expected: i32 = j * 10;
        let actual: i32 = m.get(&j);
        if actual != expected { free_intmap(m); return 10 + j; }
        j = j + 1;
    }
    // Overwrite
    m.insert(10, 9999);
    let k10: i32 = 10;
    if m.get(&k10) != 9999 { free_intmap(m); return 100; }
    // Remove + tombstone re-insert
    let k5: i32 = 5;
    m.remove(&k5);
    m.insert(5, 5555);
    if m.get(&k5) != 5555 { free_intmap(m); return 101; }

    free_intmap(m);
    return 0;
}
