// File I/O: read a file that we pre-create, return its length
fn main!() -> Int {
    let path: String = "/tmp/concrete_test_read.txt";
    let data: String = "hello world!";
    let written: Int = write_file(&path, &data);
    drop_string(data);
    let contents: String = read_file(&path);
    let len: Int = string_length(&contents);
    drop_string(contents);
    drop_string(path);
    return len;
}
