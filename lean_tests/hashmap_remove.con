// Test: HashMap remove returns None after removal
fn extract_or(opt: Option<Int>, default: Int) -> Int {
    match opt {
        Option#Some { value } => { return value; },
        Option#None => { return default; },
    }
}

fn main!() -> Int {
    let mut map: HashMap<Int, Int> = map_new::<Int, Int>();
    map_insert(&mut map, 10, 555);
    let removed: Option<Int> = map_remove(&mut map, 10);
    let got: Option<Int> = map_get(&map, 10);
    // removed should be Some(555), got should be None
    let r: Int = extract_or(removed, 0);
    let g: Int = extract_or(got, 0);
    map_free(map);
    // 555 - 555 + 0 = 0
    return r - 555 + g;
}
