// Test: remove a key and verify it is gone, other keys remain
enum Option<T> {
    Some { value: T },
    None
}

fn extract_or(opt: Option<Int>, default: Int) -> Int {
    match opt {
        Option#Some { value } => { return value; },
        Option#None {} => { return default; },
    }
}

fn main() with(Alloc) -> Int {
    let mut m: HashMap<Int, Int> = map_new::<Int, Int>();
    map_insert(&mut m, 1, 100);
    map_insert(&mut m, 2, 200);
    map_remove(&mut m, 1);
    let gone: Option<Int> = map_get(&m, 1);
    let still: Option<Int> = map_get(&m, 2);
    let len: Int = map_len(&m);
    map_free(m);
    return extract_or(gone, 0) + extract_or(still, 0) + len;
}
