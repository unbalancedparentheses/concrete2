// Test: get on non-existent key returns None
enum Option<T> {
    Some { value: T },
    None
}

fn extract_or(opt: Option<Int>, default: Int) -> Int {
    match opt {
        Option#Some { value } => { return value; },
        Option#None {} => { return default; },
    }
}

fn main() with(Alloc) -> Int {
    let mut m: HashMap<Int, Int> = map_new::<Int, Int>();
    map_insert(&mut m, 1, 100);
    let missing: Option<Int> = map_get(&m, 999);
    let result: Int = extract_or(missing, 0);
    map_free(m);
    return result;
}
