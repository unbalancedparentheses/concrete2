// Trace tests for HashMap: operation sequences with invariant checking.

fn extract_or(opt: Option<Int>, default: Int) -> Int {
    match opt {
        Option#Some { value } => { return value; },
        Option#None => { return default; },
    }
}

// Insert N keys, verify all present, check length
fn test_insert_and_get(n: Int) with(Alloc) -> Int {
    let mut map: HashMap<Int, Int> = map_new::<Int, Int>();
    let mut i: Int = 0;
    while i < n {
        map_insert(&mut map, i, i * 10);
        i = i + 1;
    }
    let len: Int = map_len(&map);
    let mut ok: Int = 1;
    i = 0;
    while i < n {
        let v: Option<Int> = map_get(&map, i);
        if extract_or(v, -1) != i * 10 { ok = 0; }
        i = i + 1;
    }
    map_free(map);
    if len != n { return 1; }
    if ok != 1 { return 1; }
    return 0;
}

// Insert same key multiple times, verify latest value wins
fn test_overwrite() with(Alloc) -> Int {
    let mut map: HashMap<Int, Int> = map_new::<Int, Int>();
    map_insert(&mut map, 1, 100);
    map_insert(&mut map, 1, 200);
    map_insert(&mut map, 1, 300);
    let len: Int = map_len(&map);
    let v: Option<Int> = map_get(&map, 1);
    let val: Int = extract_or(v, 0);
    map_free(map);
    if len != 1 { return 1; }
    if val != 300 { return 1; }
    return 0;
}

// Insert then remove, verify absent keys and remaining keys
fn test_insert_remove_cycle() with(Alloc) -> Int {
    let mut map: HashMap<Int, Int> = map_new::<Int, Int>();
    let mut i: Int = 0;
    while i < 20 {
        map_insert(&mut map, i, i);
        i = i + 1;
    }
    // Remove even keys
    i = 0;
    while i < 20 {
        map_remove(&mut map, i);
        i = i + 2;
    }
    let len: Int = map_len(&map);
    // Check odd keys present
    let mut ok: Int = 1;
    i = 1;
    while i < 20 {
        let v: Option<Int> = map_get(&map, i);
        if extract_or(v, -1) != i { ok = 0; }
        i = i + 2;
    }
    // Check even keys absent
    i = 0;
    while i < 20 {
        let v: Option<Int> = map_get(&map, i);
        if extract_or(v, -1) != -1 { ok = 0; }
        i = i + 2;
    }
    map_free(map);
    if len != 10 { return 1; }
    if ok != 1 { return 1; }
    return 0;
}

// Remove then re-insert (tombstone recovery)
fn test_tombstone_reuse() with(Alloc) -> Int {
    let mut map: HashMap<Int, Int> = map_new::<Int, Int>();
    map_insert(&mut map, 5, 50);
    map_remove(&mut map, 5);
    let v1: Option<Int> = map_get(&map, 5);
    let absent: Int = extract_or(v1, -1);
    map_insert(&mut map, 5, 99);
    let v2: Option<Int> = map_get(&map, 5);
    let present: Int = extract_or(v2, -1);
    let len: Int = map_len(&map);
    map_free(map);
    if absent != -1 { return 1; }
    if present != 99 { return 1; }
    if len != 1 { return 1; }
    return 0;
}

// Stress: insert enough to trigger growth, verify all survive
fn test_growth_stress() with(Alloc) -> Int {
    let mut map: HashMap<Int, Int> = map_new::<Int, Int>();
    let mut i: Int = 0;
    while i < 200 {
        map_insert(&mut map, i, i * 7);
        i = i + 1;
    }
    let len: Int = map_len(&map);
    let mut ok: Int = 1;
    i = 0;
    while i < 200 {
        let v: Option<Int> = map_get(&map, i);
        if extract_or(v, -1) != i * 7 { ok = 0; }
        i = i + 1;
    }
    map_free(map);
    if len != 200 { return 1; }
    if ok != 1 { return 1; }
    return 0;
}

fn main!() -> Int {
    let mut r: Int = 0;
    r = r + test_insert_and_get(0);
    r = r + test_insert_and_get(1);
    r = r + test_insert_and_get(10);
    r = r + test_insert_and_get(50);
    r = r + test_overwrite();
    r = r + test_insert_remove_cycle();
    r = r + test_tombstone_reuse();
    r = r + test_growth_stress();
    return r;
}
