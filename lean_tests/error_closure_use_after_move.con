// Error: use struct after it's been moved into closure capture
// Expected error: "used after move"

struct Pair { x: Int, y: Int }

fn consume_pair(p: Pair) -> Int {
    return p.x + p.y;
}

fn apply(f: fn(Int) -> Int, x: Int) -> Int {
    return f(x);
}

fn main!() -> Int {
    let p: Pair = Pair { x: 10, y: 20 };
    let f: fn(Int) -> Int = fn(x: Int) -> Int { return consume_pair(p); };
    let result: Int = apply(f, 0);
    // p was moved into the closure, can't use it here
    return consume_pair(p);
}
