// Test closure capturing a linear struct (move capture)
// The struct is consumed by the closure. Using it after is an error.
// Expected: 30

struct Pair { x: Int, y: Int }

fn consume_pair(p: Pair) -> Int {
    return p.x + p.y;
}

fn apply(f: fn(Int) -> Int, x: Int) -> Int {
    return f(x);
}

fn main!() -> Int {
    let p: Pair = Pair { x: 10, y: 20 };
    let result: Int = apply(fn(x: Int) -> Int { return consume_pair(p); }, 0);
    return result;
}
