// Trusted fn does ptr work AND allocates — ptr ops don't need Unsafe, allocation still needs Alloc
// NOTE: ptr deref segfaults at runtime; this test verifies the semantic check passes
trusted fn alloc_and_deref(p: *const i32) with(Alloc) -> i32 {
    let mut v: Vec<Int> = vec_new::<Int>();
    vec_push(&mut v, 99);
    vec_free(v);
    return 0;
}

fn main() with(Alloc, Unsafe) -> i32 {
    let x: i32 = 10;
    let p: *const i32 = &x as *const i32;
    let _result: i32 = alloc_and_deref(p);
    return 0;
}
