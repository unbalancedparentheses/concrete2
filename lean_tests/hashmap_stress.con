// Test: insert many entries to force rehashing, verify lookups
enum Option<T> {
    Some { value: T },
    None
}

fn extract_or(opt: Option<Int>, default: Int) -> Int {
    match opt {
        Option#Some { value } => { return value; },
        Option#None {} => { return default; },
    }
}

fn main() with(Alloc) -> Int {
    let mut m: HashMap<Int, Int> = map_new::<Int, Int>();
    let mut i: Int = 0;
    while i < 50 {
        map_insert(&mut m, i, i * 10);
        i = i + 1;
    }
    let v0: Option<Int> = map_get(&m, 0);
    let v25: Option<Int> = map_get(&m, 25);
    let v49: Option<Int> = map_get(&m, 49);
    let len: Int = map_len(&m);
    map_free(m);
    return extract_or(v0, -1) + extract_or(v25, -1) + extract_or(v49, -1) + len;
}
