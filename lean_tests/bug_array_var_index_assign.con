// Bug 004: arr[i] = val with variable index writes to wrong location.
// Expected: 42. Currently broken — returns wrong value.
// This test should FAIL until the bug is fixed.
// When fixed, register as: run_ok ... 42

fn main() -> i32 {
    let arr: [i32; 3] = [0, 0, 0];
    let i: i32 = 1;
    arr[i] = 99;
    // arr[1] should be 99 after the assignment
    let val: i32 = arr[1];
    if val == 99 {
        return 42;
    }
    return 1;
}
