// BUG TEST: integer match does not check consumption agreement.
// Only one arm consumes r — the checker should reject this but doesn't.

struct Resource {
    value: Int,
}

fn consume(r: Resource) -> Int {
    return r.value;
}

fn int_match_disagree(x: Int) -> Int {
    let r: Resource = Resource { value: 100 };
    match x {
        1 => { let _v: Int = consume(r); },
        _ => { let _v: Int = 0; },
    }
    // r might or might not be consumed depending on runtime value
    // The checker should reject this, but the int-match path resets to envBefore
    return 0;
}

fn main() -> Int {
    return int_match_disagree(1);
}
