mod test {
    import std.io.{print};

    pub fn assert_eq<T>(expected: T, result: T, message: String) -> bool {
        if expected != result {
            let msg: String = "Assert error:";
            print(&msg);
            msg.drop();
            print(&message);
            return false;
        }
        return true;
    }

    pub fn assert_ne<T>(a: T, b: T, message: String) -> bool {
        if a == b {
            let msg: String = "Assert error (expected not equal):";
            print(&msg);
            msg.drop();
            print(&message);
            return false;
        }
        return true;
    }

    pub fn assert_true(value: bool, message: String) -> bool {
        if !value {
            let msg: String = "Assert error (expected true):";
            print(&msg);
            msg.drop();
            print(&message);
            return false;
        }
        return true;
    }

    pub fn assert_false(value: bool, message: String) -> bool {
        if value {
            let msg: String = "Assert error (expected false):";
            print(&msg);
            msg.drop();
            print(&message);
            return false;
        }
        return true;
    }
}
